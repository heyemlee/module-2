# ---- App ----
ENVIRONMENT=development
DEBUG=true
CONTRACT_VERSION=module2.v1
UNITS=inches

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database ----
# MVP: SQLite (zero ops). Later swap to Postgres by changing only this URL.
DATABASE_URL=sqlite:///./data/module2.db
# DATABASE_URL=postgresql+psycopg://module2:module2@db:5432/module2

# ---- CORS (JSON array) ----
CORS_ORIGINS=["*"]
