{
  "$defs": {
    "Blocker": {
      "description": "A reason something cannot proceed. `owner` decides who must fix it.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "owner": {
          "title": "Owner",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field"
        }
      },
      "required": [
        "code",
        "owner",
        "message"
      ],
      "title": "Blocker",
      "type": "object"
    },
    "CabinetRecord": {
      "properties": {
        "cabinet_id": {
          "title": "Cabinet Id",
          "type": "string"
        },
        "source_cabinet_id": {
          "title": "Source Cabinet Id",
          "type": "string"
        },
        "cabinet_code": {
          "title": "Cabinet Code",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "width": {
          "title": "Width",
          "type": "number"
        },
        "depth": {
          "title": "Depth",
          "type": "number"
        },
        "height": {
          "title": "Height",
          "type": "number"
        },
        "panels": {
          "items": {
            "type": "string"
          },
          "title": "Panels",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        }
      },
      "required": [
        "cabinet_id",
        "source_cabinet_id",
        "cabinet_code",
        "type",
        "width",
        "depth",
        "height"
      ],
      "title": "CabinetRecord",
      "type": "object"
    },
    "CutBlock": {
      "description": "Stage-3 unit: pieces of one length, side by side, ripped from a strip block.\n\nAll pieces share `length` (one crosscut frees the block); their widths sum within\nthe strip's rip width. A block with a single piece is the degenerate 2-stage case.",
      "properties": {
        "length": {
          "title": "Length",
          "type": "number"
        },
        "pieces": {
          "items": {
            "$ref": "#/$defs/CutPiece"
          },
          "title": "Pieces",
          "type": "array"
        }
      },
      "required": [
        "length"
      ],
      "title": "CutBlock",
      "type": "object"
    },
    "CutGroup": {
      "description": "Phase A: grouping by material/thickness/finish/sheet. Phase B will add the\nstack_efficiency nesting/layout payload.",
      "properties": {
        "group_id": {
          "title": "Group Id",
          "type": "string"
        },
        "material": {
          "title": "Material",
          "type": "string"
        },
        "thickness": {
          "title": "Thickness",
          "type": "number"
        },
        "finish": {
          "title": "Finish",
          "type": "string"
        },
        "sheet_size": {
          "title": "Sheet Size",
          "type": "string"
        },
        "panels": {
          "items": {
            "type": "string"
          },
          "title": "Panels",
          "type": "array"
        }
      },
      "required": [
        "group_id",
        "material",
        "thickness",
        "finish",
        "sheet_size"
      ],
      "title": "CutGroup",
      "type": "object"
    },
    "CutPiece": {
      "description": "One physical panel placed on a strip (cut dimensions, mm).\n\nCarries material/thickness/finish so pieces from many panels — and many orders\nin a batch — can be grouped uniformly without the source PanelBOM.",
      "properties": {
        "panel_id": {
          "title": "Panel Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "cabinet_id": {
          "title": "Cabinet Id",
          "type": "string"
        },
        "order_id": {
          "default": "",
          "title": "Order Id",
          "type": "string"
        },
        "material": {
          "title": "Material",
          "type": "string"
        },
        "thickness": {
          "title": "Thickness",
          "type": "number"
        },
        "finish": {
          "title": "Finish",
          "type": "string"
        },
        "length": {
          "title": "Length",
          "type": "number"
        },
        "width": {
          "title": "Width",
          "type": "number"
        }
      },
      "required": [
        "panel_id",
        "name",
        "cabinet_id",
        "material",
        "thickness",
        "finish",
        "length",
        "width"
      ],
      "title": "CutPiece",
      "type": "object"
    },
    "CutSheet": {
      "description": "One bin ripped into strips: a fresh stock sheet, or a recovered offcut.",
      "properties": {
        "sheet_no": {
          "title": "Sheet No",
          "type": "integer"
        },
        "sheet_size": {
          "title": "Sheet Size",
          "type": "string"
        },
        "from_offcut_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "From Offcut Id"
        },
        "pattern_id": {
          "default": "",
          "title": "Pattern Id",
          "type": "string"
        },
        "usable_width": {
          "title": "Usable Width",
          "type": "number"
        },
        "usable_length": {
          "default": 0.0,
          "title": "Usable Length",
          "type": "number"
        },
        "used_width": {
          "title": "Used Width",
          "type": "number"
        },
        "offcut_width": {
          "title": "Offcut Width",
          "type": "number"
        },
        "offcut_reusable": {
          "title": "Offcut Reusable",
          "type": "boolean"
        },
        "strips": {
          "items": {
            "$ref": "#/$defs/CutStrip"
          },
          "title": "Strips",
          "type": "array"
        }
      },
      "required": [
        "sheet_no",
        "sheet_size",
        "usable_width",
        "used_width",
        "offcut_width",
        "offcut_reusable"
      ],
      "title": "CutSheet",
      "type": "object"
    },
    "CutStrip": {
      "description": "A rip-width strip crosscut into blocks (stage 2), each block ripped into pieces\nof that block's length (stage 3) — the 3-stage guillotine structure.",
      "properties": {
        "strip_no": {
          "title": "Strip No",
          "type": "integer"
        },
        "rip_width": {
          "title": "Rip Width",
          "type": "number"
        },
        "usable_length": {
          "title": "Usable Length",
          "type": "number"
        },
        "used_length": {
          "title": "Used Length",
          "type": "number"
        },
        "offcut_length": {
          "title": "Offcut Length",
          "type": "number"
        },
        "offcut_reusable": {
          "title": "Offcut Reusable",
          "type": "boolean"
        },
        "skip_trim": {
          "default": false,
          "title": "Skip Trim",
          "type": "boolean"
        },
        "blocks": {
          "items": {
            "$ref": "#/$defs/CutBlock"
          },
          "title": "Blocks",
          "type": "array"
        }
      },
      "required": [
        "strip_no",
        "rip_width",
        "usable_length",
        "used_length",
        "offcut_length",
        "offcut_reusable"
      ],
      "title": "CutStrip",
      "type": "object"
    },
    "CuttingPattern": {
      "description": "A distinct sheet layout cut over N stock sheets (book cutting).\n\nThe layout is identical across the repeats; only the panel labels differ per\nsheet. `books` is the stack height of each saw pass (<= max_stack), e.g. [4, 1]\nmeans cut 4 sheets stacked, then 1 — the industry-standard pattern×repeat×book form.",
      "properties": {
        "pattern_id": {
          "title": "Pattern Id",
          "type": "string"
        },
        "repeat_count": {
          "title": "Repeat Count",
          "type": "integer"
        },
        "books": {
          "items": {
            "type": "integer"
          },
          "title": "Books",
          "type": "array"
        },
        "sheet_nos": {
          "items": {
            "type": "integer"
          },
          "title": "Sheet Nos",
          "type": "array"
        },
        "layout": {
          "items": {
            "$ref": "#/$defs/PatternStrip"
          },
          "title": "Layout",
          "type": "array"
        }
      },
      "required": [
        "pattern_id",
        "repeat_count",
        "books",
        "sheet_nos"
      ],
      "title": "CuttingPattern",
      "type": "object"
    },
    "CuttingPlan": {
      "properties": {
        "objective": {
          "default": "waste",
          "title": "Objective",
          "type": "string"
        },
        "sheets_total": {
          "default": 0,
          "title": "Sheets Total",
          "type": "integer"
        },
        "fresh_sheets": {
          "default": 0,
          "title": "Fresh Sheets",
          "type": "integer"
        },
        "offcut_sheets": {
          "default": 0,
