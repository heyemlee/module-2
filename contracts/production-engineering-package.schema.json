          "title": "Material",
          "type": "string"
        },
        "thickness": {
          "title": "Thickness",
          "type": "number"
        },
        "finish": {
          "title": "Finish",
          "type": "string"
        },
        "sheet_size": {
          "title": "Sheet Size",
          "type": "string"
        },
        "sheets_total": {
          "title": "Sheets Total",
          "type": "integer"
        },
        "fresh_sheets": {
          "default": 0,
          "title": "Fresh Sheets",
          "type": "integer"
        },
        "offcut_sheets": {
          "default": 0,
          "title": "Offcut Sheets",
          "type": "integer"
        },
        "distinct_patterns": {
          "default": 0,
          "title": "Distinct Patterns",
          "type": "integer"
        },
        "pieces_total": {
          "title": "Pieces Total",
          "type": "integer"
        },
        "utilization": {
          "title": "Utilization",
          "type": "number"
        },
        "patterns": {
          "items": {
            "$ref": "#/$defs/CuttingPattern"
          },
          "title": "Patterns",
          "type": "array"
        },
        "sheets": {
          "items": {
            "$ref": "#/$defs/CutSheet"
          },
          "title": "Sheets",
          "type": "array"
        }
      },
      "required": [
        "group_id",
        "material",
        "thickness",
        "finish",
        "sheet_size",
        "sheets_total",
        "pieces_total",
        "utilization"
      ],
      "title": "CuttingPlanGroup",
      "type": "object"
    },
