          },
          "title": "Groups",
          "type": "array"
        }
      },
      "title": "CuttingPlan",
      "type": "object"
    },
    "CuttingPlanGroup": {
      "description": "Sheets for one material + thickness + finish group.",
      "properties": {
        "group_id": {
          "title": "Group Id",
          "type": "string"
